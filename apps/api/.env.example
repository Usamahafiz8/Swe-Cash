# ─── APP ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ADMIN_URL=http://localhost:3001

# ─── DATABASE (Neon - dev / PostgreSQL - prod) ────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/swecash?sslmode=require

# ─── REDIS (Upstash - dev / self-hosted - prod) ───────────────────────────────
REDIS_HOST=your-upstash-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-password
REDIS_TLS=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-gcp-oauth-client-id
GOOGLE_CLIENT_SECRET=your-gcp-oauth-client-secret

